{
  "name": "automation-app",
  "version": "1.0.0",
  "description": "Desktop automation app — mouse, keyboard, window control",
  "main": "src/server.js",
  "bin": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "pkg . --target node18-win-x64 --output dist/backend.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.1",
    "express": "^4.18.2",
    "node-window-manager": "^2.2.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
